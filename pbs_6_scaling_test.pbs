#!/bin/bash
#PBS -N 6_scaling_test
#PBS -l select=1:ncpus=8
#PBS -q small
#PBS -o logs/
#PBS -e logs/
#PBS -m ae

cd "$PBS_O_WORKDIR"

echo "Running on:"
hostname
echo "Working directory:"
pwd
echo "Job ID:"
echo "$PBS_JOBID"

SNCPUS=$(wc -l < "$PBS_NODEFILE")
echo "Allocated CPUs:"
echo "$NCPUS"

python code/scaling_test.py

echo "Job finished successfully."
